{
  "expo": {
    "name": "AWay",
    "slug": "away-motorcycle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "away",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "privacyPolicyUrl": "https://mercury-watercress-389.notion.site/Privacy-Policy-AWay-App-3467e6f5e8d780a7b9f7f8d1e919a7e2",
      "termsOfServiceUrl": "https://mercury-watercress-389.notion.site/Terms-of-service-AWay-App-3467e6f5e8d780548897ebc4caecc2e6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.away.motorcycle",
      "infoPlist": {
        "NSCameraUsageDescription": "Scatta foto per post e profilo",
        "NSPhotoLibraryUsageDescription": "Seleziona foto per post e profilo",
        "NSPhotoLibraryAddUsageDescription": "Salva immagini nella galleria",
        "NSLocationWhenInUseUsageDescription": "Localizza eventi e attiva SOS emergenza",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Rileva incidenti anche in background",
        "NSMotionUsageDescription": "Rileva cadute per funzione SOS",
        "NSUserTrackingUsageDescription": "Migliora la tua esperienza nell'app"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.away.motorcycle",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "HIGH_SAMPLING_RATE_SENSORS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/helmet-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A1A"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Consenti a AWay di usare la posizione per SOS e rilevamento incidenti"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Consenti a AWay di accedere alle tue foto",
          "cameraPermission": "Consenti a AWay di usare la fotocamera"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Consenti a AWay di rilevare il movimento per la funzione SOS"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
